local FILES = {
    { url = "https://raw.githubusercontent.com/qu3bgfadawfg53ah/test/refs/heads/main/config.lua" },
    { url = "https://raw.githubusercontent.com/qu3bgfadawfg53ah/test/refs/heads/main/globals.lua" },
    { url = "https://raw.githubusercontent.com/qu3bgfadawfg53ah/test/refs/heads/main/PlayerVisualTracker.lua" },
    { url = "https://raw.githubusercontent.com/qu3bgfadawfg53ah/test/refs/heads/main/TargetAcquisitionSystem.lua" },
    { url = "https://raw.githubusercontent.com/qu3bgfadawfg53ah/test/refs/heads/main/PlayerKinematicsControlSystem.lua" },
    { url = "https://raw.githubusercontent.com/qu3bgfadawfg53ah/test/refs/heads/main/nds.lua" },
    { url = "https://raw.githubusercontent.com/qu3bgfadawfg53ah/test/refs/heads/main/teleport.lua" },
    { url = "https://raw.githubusercontent.com/qu3bgfadawfg53ah/test/refs/heads/main/EnvironmentRenderingManagementSystem.lua" },
    { url = "https://raw.githubusercontent.com/qu3bgfadawfg53ah/test/refs/heads/main/misc.lua" },
    { url = "https://raw.githubusercontent.com/qu3bgfadawfg53ah/test/refs/heads/main/gui.lua" },
    { url = "https://raw.githubusercontent.com/qu3bgfadawfg53ah/test/refs/heads/main/main_loop.lua" },
}

local function hr()
    print(string.rep("═", 54))
end

local function log(m)
    print("[Loader] " .. tostring(m))
end

local function ok(m)
    print("[Loader] ✅ " .. tostring(m))
end

local function fail(m)
    warn("[Loader] 🔴 " .. tostring(m))
end

local function err(m)
    warn("[Loader] ❌ " .. tostring(m))
end

hr()
log("Загрузка...")
log("Файлов: " .. #FILES)
hr()
log("Шаг 1/2: загрузка файлов...")

local failed = {}
local cache = {}

for i, f in ipairs(FILES) do
    local loadOk, result = pcall(function()
        return game:HttpGet(f.url, true)
    end)

    if not loadOk then
        err(string.format("[%d/%d] ОШИБКА СЕТИ", i, #FILES))
        failed[#failed + 1] = { reason = tostring(result) }

    elseif type(result) ~= "string" or #result < 10 then
        err(string.format("[%d/%d] ПУСТОЙ / NIL ОТВЕТ", i, #FILES))
        failed[#failed + 1] = { reason = "пустой / nil ответ" }

    else
        local first = result:sub(1, 100):lower()
        if first:find("404") or first:find("not found") then
            err(string.format("[%d/%d] 404", i, #FILES))
            failed[#failed + 1] = { reason = "404 от GitHub" }
        else
            ok(string.format("[%d/%d] OK (%d bytes)", i, #FILES, #result))
            cache[i] = result
        end
    end
end

hr()

if #failed > 0 then
    fail("ПРЕРВАНО — " .. #failed .. "/" .. #FILES .. " файлов недоступны.")
    hr()
    return
end

log("Все файлы загружены. Выполняю...")
hr()

for i, f in ipairs(FILES) do
    local src = cache[i]

    local fn, compErr = loadstring(src, "@file_" .. i)
    if not fn then
        fail("Ошибка компиляции [" .. i .. "]: " .. tostring(compErr))
        hr()
        return
    end

    local runOk, runErr = pcall(fn)
    if not runOk then
        fail("Ошибка выполнения [" .. i .. "]: " .. tostring(runErr))
        hr()
        return
    end

    ok(string.format("[%d/%d] loaded", i, #FILES))
end

hr()
ok("Загрузка завершена.")
hr()
